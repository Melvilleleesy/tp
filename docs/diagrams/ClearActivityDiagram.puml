@startuml
!include style.puml
skin rose
skinparam ActivityFontSize 16
skinparam ArrowFontSize 13
skinparam ActivityBackgroundColor LightBlue
skinparam ActivityBorderColor DarkBlue

start
:User executes 'clear' command;

note right
  Command word: "clear"
  No parameters required
end note

:AddressBookParser creates ClearCommand;
:Execute ClearCommand on Model;

:Create new empty AddressBook instance;
:Model replaces current AddressBook
with the empty instance;

:Return CommandResult with
success message;

:Display "Address book has
been cleared!" to user;

stop
@enduml
