@startuml
!include style.puml
skin rose
skinparam ActivityFontSize 15
skinparam ArrowFontSize 12

start
:Input date/time string;

if () then ([String starts with "today"?])
    if () then ([Has time component?])
        :Parse as 0 days + time;
        :Validate not in past;
    else ([else])
        :Parse as 0 days + 23:59;
    endif
else ([else])
    if () then ([String starts with "tomorrow"?])
        if () then ([Has time component?])
            :Parse as 1 day + time;
            :Validate not in past;
        else ([else])
            :Parse as 1 day + 23:59;
        endif
    else ([else])
        if () then ([String is weekday?])
            if () then ([Has time component?])
                :Parse as days to next weekday + time;
            else ([else])
                :Parse as days to next weekday (23:59);
            endif
        else ([else])
            :Pass input to explicit date/time parsing;
        endif
    endif
endif

:Return DateTimeParseResult;
stop
@enduml
