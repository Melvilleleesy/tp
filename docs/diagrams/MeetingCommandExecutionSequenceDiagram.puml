@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant "m:MeetingCommand" as MeetingCommand LOGIC_COLOR
participant "r:CommandResult" as CommandResult LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant "model:Model" as Model MODEL_COLOR
end box

[-> LogicManager : execute("meeting 1 15 Mar 2026 4pm")
activate LogicManager

LogicManager -> MeetingCommand : execute(model)
activate MeetingCommand

MeetingCommand -> Model : getFilteredPersonList()
activate Model
Model --> MeetingCommand : lastShownList
deactivate Model

MeetingCommand -> Model : setPerson(personToEdit, updatedPerson)
activate Model
Model --> MeetingCommand
deactivate Model

create CommandResult
MeetingCommand -> CommandResult : CommandResult(feedbackToUser)
activate CommandResult
CommandResult --> MeetingCommand
deactivate CommandResult

MeetingCommand --> LogicManager : CommandResult
deactivate MeetingCommand

[<--LogicManager
deactivate LogicManager
@enduml
